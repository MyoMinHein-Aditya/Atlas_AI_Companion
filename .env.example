# Atlas Environment Configuration Template

# Environment (development, production)
NODE_ENV=development
PYTHON_ENV=development

# AI API Keys
# Gemini API Key for general AI tasks
GEMINI_API_KEY=
# Groq API Key (leave blank to default to Gemini, or populate to use Groq)
GROQ_API_KEY=

# Backend Configuration
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1
BACKEND_URL=http://localhost:8000

# Database Configuration (PostgreSQL)
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atlas
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atlas
